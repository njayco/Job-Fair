modules = ["go-1.21", "nodejs-20", "bash", "web", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
integrations = ["javascript_anthropic_ai_integrations:2.0.0", "stripe:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start client"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash run-dashboard.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server"

[[workflows.workflow]]
name = "Start client"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[userenv]

[userenv.shared]
STRIPE_PUBLISHABLE_KEY = "pk_live_51T2ip0K40VCZZTFqHrel6KUVlUuO0Y8dVpb6DLiKZewOy2j1LAvGHZIFsaruJQcwAWwd3tDk9lcMTMq2kMGiZea100U2Rb9SNP"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]
